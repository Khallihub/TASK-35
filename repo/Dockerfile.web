# ─── Stage 1: builder ────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

COPY package.json package-lock.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/

RUN npm ci && npm install --no-save @rollup/rollup-linux-x64-musl

COPY apps/web ./apps/web/
COPY packages/shared/src ./packages/shared/src
COPY packages/shared/tsconfig.json ./packages/shared/
COPY tsconfig.base.json ./

# Build the Vue app (skips vue-tsc check in CI for speed; typecheck is done separately)
RUN cd apps/web && npx vite build

# ─── Stage 2: nginx ───────────────────────────────────────────────────────────
FROM nginx:1.27-alpine AS runner

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# Install openssl for auto-generating self-signed certs on first startup
RUN apk add --no-cache openssl

COPY --from=builder /app/apps/web/dist /usr/share/nginx/html

# Default nginx config: HTTPS with auto-generated self-signed cert
# For HTTP-only dev mode, mount nginx.conf over this file (see docker-compose.dev.yml)
COPY nginx-ssl.conf /etc/nginx/conf.d/harborstone.conf

# Entrypoint: auto-generates self-signed cert if none is mounted
COPY web-entrypoint.sh /docker-entrypoint.d/99-harborstone-tls.sh
RUN chmod +x /docker-entrypoint.d/99-harborstone-tls.sh

EXPOSE 80 443
