{
  "name": "@harborstone/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "test": "jest --runInBand",
    "migrate": "knex --knexfile src/db/knex.ts migrate:latest",
    "seed": "knex --knexfile src/db/knex.ts seed:run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "koa": "^2.15.0",
    "koa-router": "^12.0.0",
    "koa-bodyparser": "^4.4.0",
    "knex": "^3.1.0",
    "mysql2": "^3.9.0",
    "pino": "^9.0.0",
    "bcrypt": "^5.1.0",
    "jsonwebtoken": "^9.0.0",
    "uuid": "^9.0.0",
    "sharp": "^0.33",
    "@koa/multer": "^3",
    "multer": "^1.4",
    "file-type": "^19",
    "mime-types": "^2.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa-router": "^7.4.8",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "better-sqlite3": "^9.4.3",
    "@types/better-sqlite3": "^7.6.8",
    "jest": "^29.7.0",
    "pino-pretty": "^11.0.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/multer": "^1.4",
    "@types/mime-types": "^2.1"
  }
}
